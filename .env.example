# Poker Learning Assistant — Environment Variables
# Copy to .env and fill in your values.

# Database (sync DSN for migrations, async for runtime)
POKEMIR_DB_DSN=postgresql+asyncpg://poker_user:poker_pass@localhost:5432/poker_assistant
POKEMIR_DB_DSN_SYNC=postgresql://poker_user:poker_pass@localhost:5432/poker_assistant

# Docker Compose PostgreSQL credentials (Linux dev — see docs/dev-workflow.md §2.4)
# Generate with: openssl rand -hex 16
POKEMIR_DB_PASSWORD=change-me           # required by docker-compose.yml
POKEMIR_DB_USER=poker_user              # optional; defaults to poker_user
POKEMIR_DB_NAME=poker_assistant         # optional; defaults to poker_assistant

# Recognition
POKEMIR_MODEL_DIR=./models
POKEMIR_ONNX_DEVICE=DirectML
POKEMIR_OCR_ENGINE=easyocr
POKEMIR_EASYOCR_DIR=./models/easyocr  # 不设则默认 ${POKEMIR_MODEL_DIR}/easyocr；R-10 防 ~/.EasyOCR/ 污染
POKEMIR_VISION_MODEL=HuggingFaceTB/SmolVLM-256M-Instruct

# Capture
POKEMIR_CAPTURE_INTERVAL_MS=500

# ROI
POKEMIR_ROI_DIR=./rois
POKEMIR_ROI_PROFILE=default

# Detection
POKEMIR_HASH_THRESHOLD=10

# Stats
POKEMIR_ROLLING_WINDOW=50

# API
POKEMIR_API_HOST=127.0.0.1
POKEMIR_API_PORT=8765

# Logging
POKEMIR_LOG_LEVEL=INFO
