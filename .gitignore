# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# Generic cache (R-10 env-var redirected: HF_HOME, PIP_CACHE_DIR, NPM_CONFIG_CACHE, PYTHONPYCACHEPREFIX)
.cache/

# Docker Compose data volumes (R-10: project-local, never commit DB data)
.docker-data/

# Virtual environments
.venv/
venv/
env/

# Local secrets / config
.env

# IDE / editor
.vscode/
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Project-specific
# NB: trailing comments on a pattern line are taken as part of the pattern.
# Always put comments on a SEPARATE line above the pattern.

# HuggingFace / ONNX model cache (machine-specific)
models/
# screenshots saved by test_capture
tests/output/
# baseline labeling outputs — contains player_name + raw_text PII, R-3 + ToS 边界
tools/output/
# un-vetted fixture captures (Win side)
tests/fixtures/_pending/
# local reference snapshots (Win/VPS each maintain own copies for debugging)
resource/
# persistent player registry (machine-local, may contain player names; #10)
data/
*.log
